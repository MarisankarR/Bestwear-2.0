{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Backend Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Install Frontend Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/BESTWEAR"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "npm run dev -- --host 127.0.0.1 --port 3000",
      "options": {
        "cwd": "${workspaceFolder}/BESTWEAR"
      },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    }
    ,
    {
      "label": "Test MongoDB",
      "type": "shell",
      "command": "node test-mongo.js",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Check Git Remote",
      "type": "shell",
      "command": "git remote -v && git branch --show-current",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
